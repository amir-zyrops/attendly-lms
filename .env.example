# Attendly Academic Portal - Environment Configuration
# Copy this file to .env and update with your production values
# DO NOT commit .env to version control

# ==================== PostgreSQL Database ====================
# Required for production deployment
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=attendly
DB_USER=attendly_user
DB_PASS=change_this_secure_password

# ==================== SMTP Email Service ====================
# Required for OTP email delivery
# Example: Gmail App Passwords, SendGrid, AWS SES, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@domain.com

# ==================== OTP Configuration ====================
# One-Time Password expiry in seconds (default: 10 minutes)
OTP_TTL_SECONDS=600
