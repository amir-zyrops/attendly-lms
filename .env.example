# Attendly configuration example

# SMTP settings (optional email OTP delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=securepassword
SMTP_FROM=noreply@attendly.local

# PostgreSQL database settings
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=attendly
DB_USER=attendly_user
DB_PASS=attendly_password

# OTP expiration in seconds
OTP_TTL_SECONDS=600
